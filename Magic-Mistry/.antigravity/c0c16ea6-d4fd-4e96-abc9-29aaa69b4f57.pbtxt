  file_change {
    absolute_path_uri: "file:///src/pages/TechnicianDashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect } from \'react\';\nimport { useNavigate } from \'react-router-dom\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport {\n  Wrench,\n  Calendar,\n  Clock,\n  MapPin,\n  CheckCircle2,\n  DollarSign,\n  Star,\n  Settings,\n  Power,\n  ShieldCheck,\n  Briefcase,\n  AlertCircle,\n  Eye,\n  Info,\n  Award,\n  TrendingUp,\n  UserCheck\n} from \'lucide-react\';\nimport { useAuth } from \'../context/AuthContext\';\nimport { getInitialsAvatar, formatDate, formatCurrency } from \'../utils\';\nimport { toast } from \'react-hot-toast\';\n\nexport default function TechnicianDashboard() {\n  const { user, logout } = useAuth();\n  const navigate = useNavigate();\n\n  const [activeTab, setActiveTab] = useState<\'jobs\' | \'earnings\' | \'reviews\' | \'profile\'>(\'jobs\');\n  const [availability, setAvailability] = useState<\'AVAILABLE\' | \'BUSY\' | \'OFFLINE\'>(\'AVAILABLE\');\n\n  // Internal lists\n  const [assignedJobs, setAssignedJobs] = useState<any[]>([]);\n  const [availableJobs, setAvailableJobs] = useState<any[]>([]);\n\n  // Earnings and reviews mock aggregates\n  const [stats, setStats] = useState({\n    totalEarnings: 320,\n    jobsCompleted: 4,\n    rating: 4.85,\n  });\n\n  useEffect(() => {\n    // Initial seed of Technician jobs\n    const seedAssigned = [\n      {\n        id: \'book-101\',\n        serviceId: \'ac\',\n        serviceName: \'Air Conditioner Repair\',\n        scheduledDate: new Date(Date.now() + 86400000).toISOString().split(\'T\')[0],\n        scheduledTime: \'10:00 AM\',\n        customerName: \'Marcus Aurelius\',\n        customerPhone: \'+15551112222\',\n        address: {\n          street: \'12 Imperial Palace Way\',\n          city: \'New York\',\n          state: \'NY\',\n          zipCode: \'10005\',\n        },\n        status: \'ACCEPTED\',\n        amount: 80,\n        problemDescription: \'Unit blows room-temperature air only. Fan speed controls function.\',\n      }\n    ];\n\n    const seedAvailable = [\n      {\n        id: \'book-102\',\n        serviceId: \'fridge\',\n        serviceName: \'Refrigerator Repair\',\n        scheduledDate: new Date(Date.now() + 86400000 * 2).toISOString().split(\'T\')[0],\n        scheduledTime: \'01:00 PM\',\n        customerName: \'Lucius Verus\',\n        customerPhone: \'+15550004444\',\n        address: {\n          street: \'88 Colosseum Blvd\',\n          city: \'New York\',\n          state: \'NY\',\n          zipCode: \'10008\',\n        },\n        status: \'PENDING\',\n        amount: 70,\n        problemDescription: \'Water accumulation under the vegetable crisper drawers. Ice maker working.\',\n      },\n      {\n        id: \'book-103\',\n        serviceId: \'tv\',\n        serviceName: \'LED/Smart TV Repair\',\n        scheduledDate: new Date(Date.now() + 86400000 * 3).toISOString().split(\'T\')[0],\n        scheduledTime: \'04:00 PM\',\n        customerName: \'Commodus Maximus\',\n        customerPhone: \'+15559990000\',\n        address: {\n          street: \'1 Gladiator arena Rd\',\n          city: \'New York\',\n          state: \'NY\',\n          zipCode: \'10012\',\n        },\n        status: \'PENDING\',\n        amount: 90,\n        problemDescription: \'Sound playing but display remains entirely blank. Status LED stays green.\',\n      }\n    ];\n\n    setAssignedJobs(seedAssigned);\n    setAvailableJobs(seedAvailable);\n  }, []);\n\n  const handleAcceptJob = (jobId: string) => {\n    const found = availableJobs.find((j) => j.id === jobId);\n    if (found) {\n      const updatedAvailable = availableJobs.filter((j) => j.id !== jobId);\n      const updatedAssigned = [...assignedJobs, { ...found, status: \'ACCEPTED\' }];\n\n      setAvailableJobs(updatedAvailable);\n      setAssignedJobs(updatedAssigned);\n      toast.success(\'Service job accepted! Check your assigned queue.\');\n    }\n  };\n\n  const handleUpdateStatus = (jobId: string, currentStatus: string) => {\n    let nextStatus = \'ACCEPTED\';\n    if (currentStatus === \'ACCEPTED\') {\n      nextStatus = \'IN_PROGRESS\';\n      toast.success(\'Job marked as In-Progress.\');\n    } else if (currentStatus === \'IN_PROGRESS\') {\n      nextStatus = \'COMPLETED\';\n      // Add payout to earnings\n      const job = assignedJobs.find((j) => j.id === jobId);\n      if (job) {\n        setStats((prev) => ({\n          totalEarnings: prev.totalEarnings + job.amount,\n          jobsCompleted: prev.jobsCompleted + 1,\n          rating: prev.rating,\n        }));\n      }\n      toast.success(\'Job completed successfully! Earnings logged.\');\n    }\n\n    const updated = assignedJobs.map((j) => {\n      if (j.id === jobId) {\n        return { ...j, status: nextStatus };\n      }\n      return j;\n    });\n    setAssignedJobs(updated);\n  };\n\n  const handleToggleAvailability = (status: \'AVAILABLE\' | \'BUSY\' | \'OFFLINE\') => {\n    setAvailability(status);\n    toast.success(`Availability changed to ${status.toLowerCase()}`);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-slate-950 text-slate-100 font-sans flex flex-col md:flex-row relative\">\n      {/* Sidebar Navigation */}\n      <aside className=\"w-full md:w-64 bg-slate-900 border-r border-slate-800 flex flex-col justify-between p-6 md:h-screen sticky top-0\">\n        <div className=\"flex flex-col gap-8\">\n          {/* Logo */}\n          <div className=\"flex items-center gap-3 cursor-pointer\" onClick={() => navigate(\'/\')}>\n            <div className=\"w-10 h-10 rounded-xl bg-gradient-to-tr from-cyan-600 to-blue-500 flex items-center justify-center\">\n              <Wrench className=\"w-5 h-5 text-white\" />\n            </div>\n            <div>\n              <span className=\"font-extrabold text-sm tracking-tight bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent uppercase\">\n                Magic Mistry\n              </span>\n              <p className=\"text-[9px] text-cyan-400 tracking-wider font-semibold\">PRO WORKER</p>\n            </div>\n          </div>\n\n          {/* User profile details */}\n          <div className=\"flex flex-col gap-3 p-4 bg-slate-950 rounded-xl border border-slate-800\">\n            <div className=\"flex items-center gap-3\">\n              <img\n                src={user?.avatar || getInitialsAvatar(user?.name || \'\')}\n                alt=\"avatar\"\n                className=\"w-10 h-10 rounded-full shrink-0\"\n                referrerPolicy=\"no-referrer\"\n              />\n              <div className=\"overflow-hidden\">\n                <h4 className=\"text-sm font-bold text-white truncate leading-none\">{user?.name}</h4>\n                <span className=\"text-[10px] text-slate-500 mt-1 block\">Certified Specialist</span>\n              </div>\n            </div>\n\n            {/* Availability pill trigger */}\n            <div className=\"grid grid-cols-3 gap-1 bg-slate-900 p-1 rounded-lg border border-slate-800 text-[9px] font-bold\">\n              <button\n                onClick={() => handleToggleAvailability(\'AVAILABLE\')}\n                className={`py-1 rounded text-center transition-all ${\n                  availability === \'AVAILABLE\' ? \'bg-emerald-500/10 text-emerald-400\' : \'text-slate-500 hover:text-white\'\n                }`}\n              >\n                Online\n              </button>\n              <button\n                onClick={() => handleToggleAvailability(\'BUSY\')}\n                className={`py-1 rounded text-center transition-all ${\n                  availability === \'BUSY\' ? \'bg-amber-500/10 text-amber-400\' : \'text-slate-500 hover:text-white\'\n                }`}\n              >\n                Busy\n              </button>\n              <button\n                onClick={() => handleToggleAvailability(\'OFFLINE\')}\n                className={`py-1 rounded text-center transition-all ${\n                  availability === \'OFFLINE\' ? \'bg-red-500/10 text-red-400\' : \'text-slate-500 hover:text-white\'\n                }`}\n              >\n                Offline\n              </button>\n            </div>\n          </div>\n\n          {/* Navigation Links */}\n          <nav className=\"flex flex-col gap-2\">\n            <button\n              onClick={() => setActiveTab(\'jobs\')}\n              className={`flex items-center gap-3.5 px-4 py-3 rounded-xl text-sm font-semibold transition-all ${\n                activeTab === \'jobs\'\n                  ? \'bg-blue-600 text-white shadow-lg shadow-blue-500/15\'\n                  : \'text-slate-400 hover:text-white hover:bg-slate-800/40\'\n              }`}\n            >\n              <Briefcase className=\"w-4.5 h-4.5\" /> Service Orders\n            </button>\n            <button\n              onClick={() => setActiveTab(\'earnings\')}\n              className={`flex items-center gap-3.5 px-4 py-3 rounded-xl text-sm font-semibold transition-all ${\n                activeTab === \'earnings\'\n                  ? \'bg-blue-600 text-white shadow-lg shadow-blue-500/15\'\n                  : \'text-slate-400 hover:text-white hover:bg-slate-800/40\'\n              }`}\n            >\n              <DollarSign className=\"w-4.5 h-4.5\" /> Payouts & Earnings\n            </button>\n            <button\n              onClick={() => setActiveTab(\'reviews\')}\n              className={`flex items-center gap-3.5 px-4 py-3 rounded-xl text-sm font-semibold transition-all ${\n                activeTab === \'reviews\'\n                  ? \'bg-blue-600 text-white shadow-lg shadow-blue-500/15\'\n                  : \'text-slate-400 hover:text-white hover:bg-slate-800/40\'\n              }`}\n            >\n              <Star className=\"w-4.5 h-4.5\" /> Reviews\n            </button>\n          </nav>\n        </div>\n\n        {/* Logout */}\n        <button\n          onClick={logout}\n          className=\"flex items-center gap-3.5 px-4 py-3 rounded-xl text-sm font-semibold text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors mt-8\"\n        >\n          <Power className=\"w-4.5 h-4.5\" /> Log Out Session\n        </button>\n      </aside>\n\n      {/* Main Panel Content */}\n      <main className=\"flex-1 p-6 sm:p-10 md:h-screen md:overflow-y-auto bg-slate-950\">\n        {/* Metric summary boxes */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-5 mb-8\">\n          <div className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl flex items-center justify-between\">\n            <div>\n              <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-wider\">Gross Earnings</span>\n              <p className=\"text-2xl font-extrabold text-white mt-1\">{formatCurrency(stats.totalEarnings)}</p>\n            </div>\n            <div className=\"w-10 h-10 rounded-xl bg-blue-600/10 border border-blue-500/20 flex items-center justify-center text-blue-400 shrink-0\">\n              <TrendingUp className=\"w-5 h-5\" />\n            </div>\n          </div>\n\n          <div className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl flex items-center justify-between\">\n            <div>\n              <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-wider\">Jobs Completed</span>\n              <p className=\"text-2xl font-extrabold text-white mt-1\">{stats.jobsCompleted}</p>\n            </div>\n            <div className=\"w-10 h-10 rounded-xl bg-cyan-600/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 shrink-0\">\n              <CheckCircle2 className=\"w-5 h-5\" />\n            </div>\n          </div>\n\n          <div className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl flex items-center justify-between\">\n            <div>\n              <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-wider\">Expert Rating</span>\n              <p className=\"text-2xl font-extrabold text-white mt-1\">{stats.rating}<span className=\"text-amber-400 text-lg\">\342\230\205</span></p>\n            </div>\n            <div className=\"w-10 h-10 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400 shrink-0\">\n              <Award className=\"w-5 h-5\" />\n            </div>\n          </div>\n        </div>\n\n        {/* Dynamic content rendering */}\n        <div className=\"flex flex-col gap-6\">\n          {/* JOBS CATALOG */}\n          {activeTab === \'jobs\' && (\n            <div className=\"flex flex-col gap-8\">\n              {/* Assigned queue */}\n              <div className=\"flex flex-col gap-4\">\n                <h2 className=\"text-lg font-extrabold text-white flex items-center gap-2\">\n                  Assigned Repairs Queue <span className=\"text-xs font-normal text-slate-500\">({assignedJobs.filter(j => j.status !== \'COMPLETED\').length})</span>\n                </h2>\n\n                <div className=\"grid grid-cols-1 gap-4\">\n                  {assignedJobs\n                    .filter((j) => j.status !== \'COMPLETED\')\n                    .map((job) => (\n                      <div\n                        key={job.id}\n                        className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl flex flex-col md:flex-row justify-between gap-6 relative\"\n                      >\n                        <div className=\"flex flex-col gap-3\">\n                          <div className=\"flex items-center gap-3\">\n                            <h3 className=\"font-bold text-white text-base\">{job.serviceName}</h3>\n                            <span className=\"px-2 py-0.5 rounded bg-blue-500/15 text-blue-400 border border-blue-500/20 text-[10px] font-bold\">\n                              {job.status === \'ACCEPTED\' ? \'Assigned\' : \'Active\'}\n                            </span>\n                          </div>\n\n                          <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-1 text-xs text-slate-400\">\n                            <span className=\"flex items-center gap-1.5\"><Calendar className=\"w-3.5 h-3.5\" /> {formatDate(job.scheduledDate)}</span>\n                            <span className=\"flex items-center gap-1.5\"><Clock className=\"w-3.5 h-3.5\" /> {job.scheduledTime}</span>\n                            <span className=\"flex items-center gap-1.5\"><MapPin className=\"w-3.5 h-3.5\" /> {job.address.street}</span>\n                          </div>\n\n                          <div className=\"p-3 bg-slate-950/50 border border-slate-900 text-xs rounded-xl text-slate-300\">\n                            <p><strong>Customer:</strong> {job.customerName} | {job.customerPhone}</p>\n                            <p className=\"mt-1\"><strong>Symptoms:</strong> {job.problemDescription}</p>\n                          </div>\n                        </div>\n\n                        {/* Status updates */}\n                        <div className=\"flex flex-col justify-between items-end gap-3 shrink-0\">\n                          <div>\n                            <span className=\"text-[10px] text-slate-500 font-bold uppercase\">Payout</span>\n                            <p className=\"text-lg font-bold text-white text-right\">{formatCurrency(job.amount)}</p>\n                          </div>\n\n                          <button\n                            onClick={() => handleUpdateStatus(job.id, job.status)}\n                            className=\"px-4 py-2 bg-gradient-to-r from-blue-600 to-cyan-500 text-white font-bold text-xs rounded-xl shadow-lg\"\n                          >\n                            {job.status === \'ACCEPTED\' ? \'Begin On-Site Fix\' : \'Mark Job Completed\'}\n                          </button>\n                        </div>\n                      </div>\n                    ))}\n                  {assignedJobs.filter((j) => j.status !== \'COMPLETED\').length === 0 && (\n                    <div className=\"p-6 text-center bg-slate-900/20 border border-slate-900 rounded-xl text-xs text-slate-500\">\n                      You do not have any active service calls scheduled. Accept nearby orders below.\n                    </div>\n                  )}\n                </div>\n              </div>\n\n              {/* Available Orders catalog */}\n              <div className=\"flex flex-col gap-4\">\n                <h2 className=\"text-lg font-extrabold text-white\">Nearby Available Requests ({availableJobs.length})</h2>\n\n                <div className=\"grid grid-cols-1 gap-4\">\n                  {availableJobs.map((job) => (\n                    <div\n                      key={job.id}\n                      className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl flex flex-col md:flex-row justify-between gap-6\"\n                    >\n                      <div className=\"flex flex-col gap-3\">\n                        <h3 className=\"font-bold text-white text-base\">{job.serviceName}</h3>\n\n                        <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-1 text-xs text-slate-400\">\n                          <span className=\"flex items-center gap-1.5\"><Calendar className=\"w-3.5 h-3.5\" /> {formatDate(job.scheduledDate)}</span>\n                          <span className=\"flex items-center gap-1.5\"><Clock className=\"w-3.5 h-3.5\" /> {job.scheduledTime}</span>\n                          <span className=\"flex items-center gap-1.5\"><MapPin className=\"w-3.5 h-3.5\" /> {job.address.city}, {job.address.zipCode}</span>\n                        </div>\n\n                        <p className=\"text-xs text-slate-400\"><strong>Issue reported:</strong> {job.problemDescription}</p>\n                      </div>\n\n                      <div className=\"flex flex-col justify-between items-end gap-3 shrink-0\">\n                        <div>\n                          <span className=\"text-[10px] text-slate-500 font-bold uppercase\">Estimated Yield</span>\n                          <p className=\"text-lg font-bold text-white text-right\">{formatCurrency(job.amount)}</p>\n                        </div>\n\n                        <button\n                          onClick={() => handleAcceptJob(job.id)}\n                          className=\"px-4 py-2 bg-slate-900 hover:bg-blue-600 hover:text-white text-blue-400 font-bold text-xs rounded-xl border border-slate-800 hover:border-transparent transition-all\"\n                        >\n                          Accept Order Job\n                        </button>\n                      </div>\n                    </div>\n                  ))}\n                  {availableJobs.length === 0 && (\n                    <div className=\"p-6 text-center bg-slate-900/20 border border-slate-900 rounded-xl text-xs text-slate-500\">\n                      No other nearby service tickets are currently waiting for assignment.\n                    </div>\n                  )}\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* EARNINGS */}\n          {activeTab === \'earnings\' && (\n            <div className=\"flex flex-col gap-6\">\n              <h2 className=\"text-lg font-extrabold text-white\">Payout Ledger</h2>\n              <div className=\"bg-slate-900/40 border border-slate-900 rounded-2xl overflow-hidden\">\n                <table className=\"w-full text-left border-collapse text-sm\">\n                  <thead>\n                    <tr className=\"border-b border-slate-800 text-slate-400 font-bold bg-slate-900/80 text-xs uppercase tracking-wider\">\n                      <th className=\"p-4\">Reference</th>\n                      <th className=\"p-4\">Appliance Category</th>\n                      <th className=\"p-4\">Finished Date</th>\n                      <th className=\"p-4\">Net Yield</th>\n                      <th className=\"p-4\">Payout Method</th>\n                      <th className=\"p-4 text-right\">Status</th>\n                    </tr>\n                  </thead>\n                  <tbody>\n                    <tr className=\"border-b border-slate-800/50 text-xs\">\n                      <td className=\"p-4 font-mono text-slate-400\">PAY-9831</td>\n                      <td className=\"p-4 font-bold text-white\">Washing Machine Motor Repair</td>\n                      <td className=\"p-4 text-slate-300\">Jun 24, 2026</td>\n                      <td className=\"p-4 text-slate-300 font-semibold\">$65.00</td>\n                      <td className=\"p-4 text-slate-400\">Direct Deposit</td>\n                      <td className=\"p-4 text-right\">\n                        <span className=\"px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 font-bold\">\n                          Settled\n                        </span>\n                      </td>\n                    </tr>\n                    <tr className=\"border-b border-slate-800/50 text-xs\">\n                      <td className=\"p-4 font-mono text-slate-400\">PAY-9712</td>\n                      <td className=\"p-4 font-bold text-white\">Induction Repair & IGBT replace</td>\n                      <td className=\"p-4 text-slate-300\">Jun 19, 2026</td>\n                      <td className=\"p-4 text-slate-300 font-semibold\">$80.00</td>\n                      <td className=\"p-4 text-slate-400\">Direct Deposit</td>\n                      <td className=\"p-4 text-right\">\n                        <span className=\"px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 font-bold\">\n                          Settled\n                        </span>\n                      </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          )}\n\n          {/* REVIEWS */}\n          {activeTab === \'reviews\' && (\n            <div className=\"flex flex-col gap-6\">\n              <h2 className=\"text-lg font-extrabold text-white\">Customer Reviews & Ratings</h2>\n\n              <div className=\"grid grid-cols-1 gap-4\">\n                <div className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl flex flex-col gap-3\">\n                  <div className=\"flex justify-between items-start\">\n                    <div className=\"flex items-center gap-2\">\n                      <Star className=\"w-4 h-4 fill-amber-400 text-amber-400\" />\n                      <Star className=\"w-4 h-4 fill-amber-400 text-amber-400\" />\n                      <Star className=\"w-4 h-4 fill-amber-400 text-amber-400\" />\n                      <Star className=\"w-4 h-4 fill-amber-400 text-amber-400\" />\n                      <Star className=\"w-4 h-4 fill-amber-400 text-amber-400\" />\n                      <span className=\"text-xs font-bold text-white ml-2\">5.00/5</span>\n                    </div>\n                    <span className=\"text-[10px] text-slate-500\">Jun 25, 2026</span>\n                  </div>\n                  <p className=\"text-slate-300 text-xs italic leading-relaxed\">\n                    \"Super polite and fast. Had my washing machine motor repaired and spin-tested inside of 30 minutes! Excellent craftsmanship and cleaned up after completing the work.\"\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-semibold uppercase\">\342\200\224 Sarah Connor, TV Repair</span>\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n      </main>\n    </div>\n  );\n}\n"
