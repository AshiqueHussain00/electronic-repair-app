  file_change {
    absolute_path_uri: "file:///src/routes/index.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React from \'react\';\nimport { Routes, Route, Navigate, useLocation } from \'react-router-dom\';\nimport { useAuth } from \'../context/AuthContext\';\nimport { UserRole } from \'../types\';\n\n// Lazy-loaded views for high performance\nimport Home from \'../pages/Home\';\nimport Login from \'../pages/Login\';\nimport Signup from \'../pages/Signup\';\nimport VerifyOTP from \'../pages/VerifyOTP\';\nimport ForgotPassword from \'../pages/ForgotPassword\';\n\n// Dashboards\nimport CustomerDashboard from \'../pages/CustomerDashboard\';\nimport TechnicianDashboard from \'../pages/TechnicianDashboard\';\nimport AdminDashboard from \'../pages/AdminDashboard\';\n\n/**\n * Guard for authenticated routes with optional role-based access control\n */\nexport const ProtectedRoute: React.FC<{ children: React.ReactNode; allowedRoles?: UserRole[] }> = ({\n  children,\n  allowedRoles,\n}) => {\n  const { isAuthenticated, user, isLoading } = useAuth();\n  const location = useLocation();\n\n  if (isLoading) {\n    return (\n      <div className=\"min-h-screen bg-slate-900 flex items-center justify-center\">\n        <div className=\"flex flex-col items-center gap-4\">\n          <div className=\"w-12 h-12 border-4 border-cyan-500 border-t-transparent rounded-full animate-spin\"></div>\n          <p className=\"text-slate-400 font-medium tracking-wide\">Authenticating Session...</p>\n        </div>\n      </div>\n    );\n  }\n\n  if (!isAuthenticated || !user) {\n    return <Navigate to=\"/login\" state={{ from: location }} replace />;\n  }\n\n  // Check roles\n  if (allowedRoles && !allowedRoles.includes(user.role)) {\n    // Redirect to their default dashboard\n    if (user.role === UserRole.ADMIN) return <Navigate to=\"/admin\" replace />;\n    if (user.role === UserRole.TECHNICIAN) return <Navigate to=\"/technician\" replace />;\n    return <Navigate to=\"/customer\" replace />;\n  }\n\n  return <>{children}</>;\n};\n\n/**\n * Guard for public-only auth routes (Login, Signup, ForgotPassword)\n */\nexport const PublicRoute: React.FC<{ children: React.ReactNode }> = ({ children }) => {\n  const { isAuthenticated, user, isLoading } = useAuth();\n\n  if (isLoading) {\n    return (\n      <div className=\"min-h-screen bg-slate-900 flex items-center justify-center\">\n        <div className=\"flex flex-col items-center gap-4\">\n          <div className=\"w-12 h-12 border-4 border-cyan-500 border-t-transparent rounded-full animate-spin\"></div>\n          <p className=\"text-slate-400 font-medium tracking-wide\">Verifying Access...</p>\n        </div>\n      </div>\n    );\n  }\n\n  if (isAuthenticated && user) {\n    if (user.role === UserRole.ADMIN) return <Navigate to=\"/admin\" replace />;\n    if (user.role === UserRole.TECHNICIAN) return <Navigate to=\"/technician\" replace />;\n    return <Navigate to=\"/customer\" replace />;\n  }\n\n  return <>{children}</>;\n};\n\nexport const AppRoutes: React.FC = () => {\n  return (\n    <Routes>\n      {/* Public Pages */}\n      <Route path=\"/\" element={<Home />} />\n\n      {/* Auth Pages (Protected from logged-in users) */}\n      <Route\n        path=\"/login\"\n        element={\n          <PublicRoute>\n            <Login />\n          </PublicRoute>\n        }\n      />\n      <Route\n        path=\"/signup\"\n        element={\n          <PublicRoute>\n            <Signup />\n          </PublicRoute>\n        }\n      />\n      <Route\n        path=\"/verify-otp\"\n        element={\n          <PublicRoute>\n            <VerifyOTP />\n          </PublicRoute>\n        }\n      />\n      <Route\n        path=\"/forgot-password\"\n        element={\n          <PublicRoute>\n            <ForgotPassword />\n          </PublicRoute>\n        }\n      />\n\n      {/* Role Protected Dashboards */}\n      <Route\n        path=\"/customer/*\"\n        element={\n          <ProtectedRoute allowedRoles={[UserRole.CUSTOMER]}>\n            <CustomerDashboard />\n          </ProtectedRoute>\n        }\n      />\n      <Route\n        path=\"/technician/*\"\n        element={\n          <ProtectedRoute allowedRoles={[UserRole.TECHNICIAN]}>\n            <TechnicianDashboard />\n          </ProtectedRoute>\n        }\n      />\n      <Route\n        path=\"/admin/*\"\n        element={\n          <ProtectedRoute allowedRoles={[UserRole.ADMIN]}>\n            <AdminDashboard />\n          </ProtectedRoute>\n        }\n      />\n\n      {/* Fallback Catch-all Route */}\n      <Route path=\"*\" element={<Navigate to=\"/\" replace />} />\n    </Routes>\n  );\n};\n"
    }
