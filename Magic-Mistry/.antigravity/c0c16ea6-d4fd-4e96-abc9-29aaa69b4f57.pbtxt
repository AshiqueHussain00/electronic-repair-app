  file_change {
    absolute_path_uri: "file:///src/pages/AdminDashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \'react\';\nimport { useNavigate } from \'react-router-dom\';\nimport { motion } from \'motion/react\';\nimport {\n  ShieldAlert,\n  Users,\n  Wrench,\n  Calendar,\n  CreditCard,\n  Settings,\n  Power,\n  TrendingUp,\n  Sliders,\n  DollarSign,\n  Plus,\n  CheckCircle,\n  AlertCircle,\n  XCircle,\n  Clock\n} from \'lucide-react\';\nimport { useAuth } from \'../context/AuthContext\';\nimport { getInitialsAvatar, formatDate, formatCurrency } from \'../utils\';\nimport { toast } from \'react-hot-toast\';\n\nexport default function AdminDashboard() {\n  const { user, logout } = useAuth();\n  const navigate = useNavigate();\n\n  const [activeTab, setActiveTab] = useState<\'overview\' | \'users\' | \'bookings\' | \'payments\'>(\'overview\');\n\n  // Admin states\n  const [systemUsers, setSystemUsers] = useState([\n    { id: \'usr-1\', name: \'Azad Ansari\', email: \'ansariazad7864@gmail.com\', role: \'CUSTOMER\', status: \'ACTIVE\', joined: \'2026-06-01\' },\n    { id: \'usr-2\', name: \'Marcus Aurelius\', email: \'marcus@rome.gov\', role: \'CUSTOMER\', status: \'ACTIVE\', joined: \'2026-06-10\' },\n    { id: \'usr-3\', name: \'John Electrician\', email: \'tech@magicmistry.com\', role: \'TECHNICIAN\', status: \'ACTIVE\', joined: \'2026-06-05\' },\n    { id: \'usr-4\', name: \'Sarah Connor\', email: \'sarah@resistance.net\', role: \'CUSTOMER\', status: \'ACTIVE\', joined: \'2026-06-12\' },\n    { id: \'usr-5\', name: \'Lucius Verus\', email: \'lucius@co-emperor.gov\', role: \'CUSTOMER\', status: \'SUSPENDED\', joined: \'2026-06-15\' },\n  ]);\n\n  const [systemBookings, setSystemBookings] = useState([\n    { id: \'book-201\', customer: \'Azad Ansari\', service: \'Air Conditioner Repair\', date: \'2026-06-28\', status: \'ACCEPTED\', amount: 80 },\n    { id: \'book-202\', customer: \'Sarah Connor\', service: \'LED/Smart TV Repair\', date: \'2026-06-22\', status: \'COMPLETED\', amount: 90 },\n    { id: \'book-203\', customer: \'Lucius Verus\', service: \'Refrigerator Repair\', date: \'2026-06-29\', status: \'PENDING\', amount: 70 },\n  ]);\n\n  const handleToggleUserStatus = (userId: string) => {\n    const updated = systemUsers.map((u) => {\n      if (u.id === userId) {\n        const nextStatus = u.status === \'ACTIVE\' ? \'SUSPENDED\' : \'ACTIVE\';\n        toast.success(`User status changed to ${nextStatus}`);\n        return { ...u, status: nextStatus };\n      }\n      return u;\n    });\n    setSystemUsers(updated);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-slate-950 text-slate-100 font-sans flex flex-col md:flex-row relative\">\n      {/* Sidebar Navigation */}\n      <aside className=\"w-full md:w-64 bg-slate-900 border-r border-slate-800 flex flex-col justify-between p-6 md:h-screen sticky top-0\">\n        <div className=\"flex flex-col gap-8\">\n          {/* Logo */}\n          <div className=\"flex items-center gap-3 cursor-pointer\" onClick={() => navigate(\'/\')}>\n            <div className=\"w-10 h-10 rounded-xl bg-gradient-to-tr from-blue-600 to-cyan-500 flex items-center justify-center\">\n              <ShieldAlert className=\"w-5 h-5 text-white\" />\n            </div>\n            <div>\n              <span className=\"font-extrabold text-sm tracking-tight bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent uppercase\">\n                Magic Mistry\n              </span>\n              <p className=\"text-[9px] text-cyan-400 tracking-wider font-semibold\">ADMIN CENTER</p>\n            </div>\n          </div>\n\n          {/* Admin Account Header */}\n          <div className=\"flex items-center gap-3 p-3 bg-slate-950 rounded-xl border border-slate-800\">\n            <img\n              src={user?.avatar || getInitialsAvatar(user?.name || \'\')}\n              alt=\"avatar\"\n              className=\"w-10 h-10 rounded-full shrink-0\"\n              referrerPolicy=\"no-referrer\"\n            />\n            <div className=\"overflow-hidden\">\n              <h4 className=\"text-sm font-bold text-white truncate leading-none\">{user?.name}</h4>\n              <span className=\"text-[10px] text-red-400 mt-1 block font-bold tracking-wide uppercase\">Super Admin</span>\n            </div>\n          </div>\n\n          {/* Tab Links */}\n          <nav className=\"flex flex-col gap-2\">\n            <button\n              onClick={() => setActiveTab(\'overview\')}\n              className={`flex items-center gap-3.5 px-4 py-3 rounded-xl text-sm font-semibold transition-all ${\n                activeTab === \'overview\'\n                  ? \'bg-blue-600 text-white shadow-lg shadow-blue-500/15\'\n                  : \'text-slate-400 hover:text-white hover:bg-slate-800/40\'\n              }`}\n            >\n              <Sliders className=\"w-4.5 h-4.5\" /> Platform Control\n            </button>\n            <button\n              onClick={() => setActiveTab(\'users\')}\n              className={`flex items-center gap-3.5 px-4 py-3 rounded-xl text-sm font-semibold transition-all ${\n                activeTab === \'users\'\n                  ? \'bg-blue-600 text-white shadow-lg shadow-blue-500/15\'\n                  : \'text-slate-400 hover:text-white hover:bg-slate-800/40\'\n              }`}\n            >\n              <Users className=\"w-4.5 h-4.5\" /> Registry Accounts\n            </button>\n            <button\n              onClick={() => setActiveTab(\'bookings\')}\n              className={`flex items-center gap-3.5 px-4 py-3 rounded-xl text-sm font-semibold transition-all ${\n                activeTab === \'bookings\'\n                  ? \'bg-blue-600 text-white shadow-lg shadow-blue-500/15\'\n                  : \'text-slate-400 hover:text-white hover:bg-slate-800/40\'\n              }`}\n            >\n              <Calendar className=\"w-4.5 h-4.5\" /> Total Repair Orders\n            </button>\n          </nav>\n        </div>\n\n        {/* Logout */}\n        <button\n          onClick={logout}\n          className=\"flex items-center gap-3.5 px-4 py-3 rounded-xl text-sm font-semibold text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors mt-8\"\n        >\n          <Power className=\"w-4.5 h-4.5\" /> Log Out Session\n        </button>\n      </aside>\n\n      {/* Main Panel Content */}\n      <main className=\"flex-1 p-6 sm:p-10 md:h-screen md:overflow-y-auto bg-slate-950\">\n        {/* Aggregated Counters */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-4 gap-5 mb-8\">\n          <div className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl\">\n            <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-wider\">Net GMV Revenue</span>\n            <p className=\"text-2xl font-extrabold text-white mt-1\">$12,420</p>\n          </div>\n          <div className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl\">\n            <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-wider\">Total Bookings</span>\n            <p className=\"text-2xl font-extrabold text-white mt-1\">421</p>\n          </div>\n          <div className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl\">\n            <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-wider\">Platform Providers</span>\n            <p className=\"text-2xl font-extrabold text-white mt-1\">34</p>\n          </div>\n          <div className=\"p-5 bg-slate-900/40 border border-slate-900 rounded-2xl\">\n            <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-wider\">Security Audits</span>\n            <p className=\"text-2xl font-extrabold text-emerald-400 mt-1\">Pass \342\234\223</p>\n          </div>\n        </div>\n\n        {/* Dynamic content rendering */}\n        <div className=\"flex flex-col gap-6\">\n          {/* OVERVIEW CONTROL PANEL */}\n          {activeTab === \'overview\' && (\n            <div className=\"flex flex-col gap-6\">\n              <h2 className=\"text-lg font-extrabold text-white\">System Controls</h2>\n              <div className=\"p-6 bg-slate-900/40 border border-slate-900 rounded-2xl flex flex-col sm:flex-row gap-6 items-center justify-between\">\n                <div>\n                  <h3 className=\"font-bold text-white text-base\">Automatic Dispatch Routing</h3>\n                  <p className=\"text-slate-400 text-xs mt-1\">\n                    Toggle system-wide direct mechanics notifications on booking submit.\n                  </p>\n                </div>\n                <button\n                  onClick={() => toast.success(\'Auto dispatch routing system set to auto.\')}\n                  className=\"px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold text-xs rounded-xl shadow-lg\"\n                >\n                  Configure Dispatch\n                </button>\n              </div>\n\n              {/* Maintenance summary log */}\n              <div className=\"p-6 bg-slate-900/40 border border-slate-900 rounded-2xl\">\n                <h3 className=\"font-bold text-white text-base mb-4\">Platform System Diagnostics</h3>\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-semibold\">\n                  <div className=\"p-3.5 bg-slate-950 border border-slate-900 rounded-xl flex items-center justify-between\">\n                    <span className=\"text-slate-400\">Database Cluster Connection</span>\n                    <span className=\"text-emerald-400 font-bold\">Stable (0.2ms)</span>\n                  </div>\n                  <div className=\"p-3.5 bg-slate-950 border border-slate-900 rounded-xl flex items-center justify-between\">\n                    <span className=\"text-slate-400\">Secure SMTP Mailer Relay</span>\n                    <span className=\"text-emerald-400 font-bold\">Active</span>\n                  </div>\n                  <div className=\"p-3.5 bg-slate-950 border border-slate-900 rounded-xl flex items-center justify-between\">\n                    <span className=\"text-slate-400\">API Server Container Node</span>\n                    <span className=\"text-emerald-400 font-bold\">Online</span>\n                  </div>\n                  <div className=\"p-3.5 bg-slate-950 border border-slate-900 rounded-xl flex items-center justify-between\">\n                    <span className=\"text-slate-400\">Live WebSockets channels</span>\n                    <span className=\"text-emerald-400 font-bold\">Ready</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* USERS REGISTRY */}\n          {activeTab === \'users\' && (\n            <div className=\"flex flex-col gap-6\">\n              <h2 className=\"text-lg font-extrabold text-white\">Registered Customer & Providers Accounts</h2>\n              <div className=\"bg-slate-900/40 border border-slate-900 rounded-2xl overflow-hidden\">\n                <table className=\"w-full text-left border-collapse text-sm\">\n                  <thead>\n                    <tr className=\"border-b border-slate-800 text-slate-400 font-bold bg-slate-900/80 text-xs uppercase tracking-wider\">\n                      <th className=\"p-4\">User Details</th>\n                      <th className=\"p-4\">Account Type</th>\n                      <th className=\"p-4\">Joined Date</th>\n                      <th className=\"p-4\">Security Status</th>\n                      <th className=\"p-4 text-right\">Actions</th>\n                    </tr>\n                  </thead>\n                  <tbody>\n                    {systemUsers.map((u) => (\n                      <tr key={u.id} className=\"border-b border-slate-800/50 text-xs\">\n                        <td className=\"p-4\">\n                          <div className=\"flex items-center gap-3\">\n                            <img src={getInitialsAvatar(u.name)} className=\"w-8 h-8 rounded-full\" alt=\"\" />\n                            <div>\n                              <p className=\"font-bold text-white leading-none\">{u.name}</p>\n                              <span className=\"text-[10px] text-slate-500 mt-1 block\">{u.email}</span>\n                            </div>\n                          </div>\n                        </td>\n                        <td className=\"p-4\">\n                          <span\n                            className={`px-2 py-0.5 rounded text-[10px] font-bold ${\n                              u.role === \'ADMIN\'\n                                ? \'bg-red-500/10 text-red-400 border border-red-500/20\'\n                                : u.role === \'TECHNICIAN\'\n                                  ? \'bg-cyan-500/10 text-cyan-400 border border-cyan-500/20\'\n                                  : \'bg-blue-500/10 text-blue-400 border border-blue-500/20\'\n                            }`}\n                          >\n                            {u.role}\n                          </span>\n                        </td>\n                        <td className=\"p-4 text-slate-300\">{formatDate(u.joined)}</td>\n                        <td className=\"p-4\">\n                          <span\n                            className={`px-2 py-0.5 rounded text-[10px] font-bold ${\n                              u.status === \'ACTIVE\'\n                                ? \'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20\'\n                                : \'bg-red-500/10 text-red-400 border border-red-500/20\'\n                            }`}\n                          >\n                            {u.status}\n                          </span>\n                        </td>\n                        <td className=\"p-4 text-right\">\n                          <button\n                            onClick={() => handleToggleUserStatus(u.id)}\n                            className=\"text-xs text-blue-400 font-bold hover:underline\"\n                          >\n                            {u.status === \'ACTIVE\' ? \'Suspend\' : \'Activate\'}\n                          </button>\n                        </td>\n                      </tr>\n                    ))}\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          )}\n\n          {/* PLATFORM BOOKINGS */}\n          {activeTab === \'bookings\' && (\n            <div className=\"flex flex-col gap-6\">\n              <h2 className=\"text-lg font-extrabold text-white\">Platform Repair Orders List</h2>\n              <div className=\"bg-slate-900/40 border border-slate-900 rounded-2xl overflow-hidden\">\n                <table className=\"w-full text-left border-collapse text-sm\">\n                  <thead>\n                    <tr className=\"border-b border-slate-800 text-slate-400 font-bold bg-slate-900/80 text-xs uppercase tracking-wider\">\n                      <th className=\"p-4\">ID Reference</th>\n                      <th className=\"p-4\">Client</th>\n                      <th className=\"p-4\">Service Required</th>\n                      <th className=\"p-4\">Scheduled Date</th>\n                      <th className=\"p-4\">Bill Amount</th>\n                      <th className=\"p-4 text-right\">Assignment Status</th>\n                    </tr>\n                  </thead>\n                  <tbody>\n                    {systemBookings.map((b) => (\n                      <tr key={b.id} className=\"border-b border-slate-800/50 text-xs\">\n                        <td className=\"p-4 font-mono text-slate-400\">#{b.id.toUpperCase()}</td>\n                        <td className=\"p-4 font-bold text-white\">{b.customer}</td>\n                        <td className=\"p-4 text-slate-300\">{b.service}</td>\n                        <td className=\"p-4 text-slate-400\">{formatDate(b.date)}</td>\n                        <td className=\"p-4 text-slate-300 font-semibold\">{formatCurrency(b.amount)}</td>\n                        <td className=\"p-4 text-right\">\n                          <span\n                            className={`px-2.5 py-0.5 rounded-full text-[10px] font-bold ${\n                              b.status === \'COMPLETED\'\n                                ? \'bg-emerald-500/10 text-emerald-400\'\n                                : b.status === \'ACCEPTED\'\n                                  ? \'bg-blue-500/10 text-blue-400\'\n                                  : \'bg-yellow-500/10 text-yellow-400\'\n                            }`}\n                          >\n                            {b.status}\n                          </span>\n                        </td>\n                      </tr>\n                    ))}\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          )}\n        </div>\n      </main>\n    </div>\n  );\n}\n"
    }
